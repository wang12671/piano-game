.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: #0a0a14;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 28rpx 40rpx;
  background: linear-gradient(135deg, rgba(30, 40, 80, 0.85), rgba(20, 30, 60, 0.92));
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.4),
    0 2rpx 8rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 100;
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, transparent 50%);
  border-radius: 0 0 32rpx 32rpx;
  pointer-events: none;
}

.score-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-info.left .score-label {
  color: rgba(255, 255, 255, 0.85);
  font-weight: 300;
}

.score-info.right .score-label {
  color: rgba(150, 150, 170, 0.8);
}

.score-label {
  font-size: 22rpx;
  color: #8888aa;
  margin-bottom: 4rpx;
}

.game-title-header {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
}

.score-value {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #e8e8f0, #d0d0e0, #f5f5ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 8px rgba(200, 210, 230, 0.4);
  filter: drop-shadow(0 0 4px rgba(220, 230, 250, 0.3));
}

.score-value.best {
  background: linear-gradient(135deg, #ffd700, #ffe066, #ffc400, #ffd700);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 12px rgba(255, 215, 0, 0.6), 0 0 24px rgba(255, 215, 0, 0.4);
  filter: drop-shadow(0 0 6px rgba(255, 215, 0, 0.5));
}

.game-area {
  display: flex;
  flex-direction: column;
  width: 100%;
  flex: 1;
  overflow: hidden;
  position: relative;
  padding: 16rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(10, 10, 20, 0.95), rgba(5, 5, 15, 1));
}

/* 棋盘容器 - 全程稳定静止，无抖动晃动 */
.game-rows-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  box-shadow: 
    0 0 30rpx rgba(0, 0, 0, 0.6),
    inset 0 0 15rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
  overflow: hidden;
  /* 禁止任何transform动画，确保棋盘稳定静止 */
  transform: none !important;
  will-change: auto;
}

.game-row {
  display: flex;
  width: 100%;
  height: 10%; /* 10行，每行10%高度 */
}

/* 粒子光效 - 仅在方块内部生成局部金色高光，不带动整体棋盘 */
.tile {
  flex: 1;
  border: 1rpx solid rgba(80, 80, 80, 0.25);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  /* 禁止方块scale动画，避免整体抖动 */
  transform: none;
}

/* 黑块内部粒子光效 - 局部金色高光反馈 */
@keyframes inner-glow {
  0% {
    opacity: 1;
    transform: scale(0.8);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.1);
  }
  100% {
    opacity: 0;
    transform: scale(1.3);
  }
}

.tile-hit::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 60%;
  height: 60%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255, 215, 0, 0.5) 0%, rgba(255, 200, 100, 0.3) 30%, transparent 70%);
  border-radius: 50%;
  animation: inner-glow 0.12s ease-out forwards;
  pointer-events: none;
  z-index: 10;
}

/* 按压微光特效 - 仅在方块内部 */
.tile:active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at center, rgba(255, 215, 0, 0.15) 0%, transparent 60%);
  pointer-events: none;
  z-index: 5;
}

.tile-black {
  background: linear-gradient(180deg, #1e1e1e, #141414, #0a0a0a);
  background-image: 
    url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.15'/%3E%3C/svg%3E"),
    linear-gradient(180deg, #1e1e1e, #141414);
  background-blend-mode: overlay, normal;
  box-shadow: inset 0 1rpx 2rpx rgba(255,255,255,0.05), inset 0 -1rpx 2rpx rgba(0,0,0,0.3);
}

.tile-white {
  background: linear-gradient(180deg, #e8e4dc 0%, #d8d4cc 50%, #d0ccc4 100%);
  box-shadow: inset 0 1rpx 1rpx rgba(255,255,255,0.3), inset 0 -1rpx 1rpx rgba(0,0,0,0.05);
}

.idle-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 46, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.idle-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.game-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.game-desc {
  font-size: 28rpx;
  color: #8888aa;
  margin-bottom: 60rpx;
}

.btn {
  padding: 24rpx 80rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-start {
  background: linear-gradient(135deg, #00d4ff, #0099cc);
  color: #ffffff;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.modal-content {
  background: #16213e;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.modal-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #00d4ff;
}

.modal-label {
  font-size: 26rpx;
  color: #8888aa;
  margin-bottom: 10rpx;
}

.modal-best {
  font-size: 28rpx;
  color: #ffd700;
  margin-bottom: 20rpx;
}

.upload-result {
  font-size: 26rpx;
  color: #44ff88;
  margin-bottom: 16rpx;
}

.modal-btn {
  width: 100%;
  padding: 22rpx 0;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 16rpx;
}

.btn-upload {
  background: linear-gradient(135deg, #00d4ff, #0099cc);
  color: #ffffff;
}

.btn-restart {
  background: linear-gradient(135deg, #4444aa, #333388);
  color: #ffffff;
}

.btn-ranking {
  background: transparent;
  border: 2rpx solid #00d4ff;
  color: #00d4ff;
  margin-bottom: 0;
}
