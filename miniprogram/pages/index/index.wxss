.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: #0a0a14;
}

.header {
  display: flex;
  justify-content: space-around;
  width: 100%;
  padding: 20rpx 0;
  background: linear-gradient(135deg, rgba(26,26,46,0.95), rgba(15,15,26,0.98));
  backdrop-filter: blur(10px);
}

.score-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-label {
  font-size: 24rpx;
  color: #8888aa;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c0c0c0, #e0e0e0, #f0f0f0);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.score-value.best {
  background: linear-gradient(135deg, #ffd700, #ffec8b, #ffd700);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 10px rgba(255, 215, 0, 0.5), 0 0 20px rgba(255, 215, 0, 0.3);
}

.game-area {
  display: flex;
  flex-direction: column;
  width: 100%;
  flex: 1;
  overflow: hidden;
  position: relative;
  padding: 20rpx;
  box-sizing: border-box;
}

.game-rows-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 116.67%;
  will-change: transform;
  border-radius: 16rpx;
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.5), inset 0 0 10px rgba(255, 255, 255, 0.05);
  overflow: hidden;
}

.game-row {
  display: flex;
  width: 100%;
  height: 16.67%;
}

.tile {
  flex: 1;
  border: 1rpx solid rgba(80, 80, 80, 0.3);
  box-sizing: border-box;
}

.tile-black {
  background: #1a1a1a;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%' height='100%' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-blend-mode: overlay;
}

.tile-white {
  background: linear-gradient(180deg, #e8e4dc, #d4d0c8);
}

/* 粒子光效 */
.particle {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

@keyframes particle-burst {
  0% {
    transform: scale(0.5);
    opacity: 1;
    box-shadow: 0 0 10px rgba(255, 215, 0, 0.8);
  }
  100% {
    transform: scale(2);
    opacity: 0;
    box-shadow: 0 0 30px rgba(255, 215, 0, 0);
  }
}

.tile-hit {
  animation: particle-burst 0.1s ease-out;
}

.tile:active {
  background: #2a2a2a !important;
  box-shadow: inset 0 0 10px rgba(255, 215, 0, 0.3);
}

.idle-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 46, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.idle-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.game-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.game-desc {
  font-size: 28rpx;
  color: #8888aa;
  margin-bottom: 60rpx;
}

.btn {
  padding: 24rpx 80rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-start {
  background: linear-gradient(135deg, #00d4ff, #0099cc);
  color: #ffffff;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.modal-content {
  background: #16213e;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.modal-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #00d4ff;
}

.modal-label {
  font-size: 26rpx;
  color: #8888aa;
  margin-bottom: 10rpx;
}

.modal-best {
  font-size: 28rpx;
  color: #ffd700;
  margin-bottom: 20rpx;
}

.upload-result {
  font-size: 26rpx;
  color: #44ff88;
  margin-bottom: 16rpx;
}

.modal-btn {
  width: 100%;
  padding: 22rpx 0;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 16rpx;
}

.btn-upload {
  background: linear-gradient(135deg, #00d4ff, #0099cc);
  color: #ffffff;
}

.btn-restart {
  background: linear-gradient(135deg, #4444aa, #333388);
  color: #ffffff;
}

.btn-ranking {
  background: transparent;
  border: 2rpx solid #00d4ff;
  color: #00d4ff;
  margin-bottom: 0;
}
